{
  "name": "xeck",
  "version": "1.0.1",
  "description": "Xeck",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/xai3ra/xeck.git"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder -w",
    "clean": "rd /s /q release",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.xeck.app",
    "productName": "Xeck",
    "publish": [
      {
        "provider": "github",
        "owner": "xai3ra",
        "repo": "xeck"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}.${ext}"
    },
    "asar": true,
    "files": [
      "**/*",
      "!Contracts/**/*",
      "!contracts.db",
      "!.gitignore"
    ],
    "directories": {
      "output": "release"
    }
  },
  "keywords": [],
  "author": "Xeck Team",
  "license": "ISC",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "electron-updater": "^6.1.7",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "sqlite3": "5.1.6"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3"
  }
}
